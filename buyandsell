class Solution {
    public int maxProfit(int[] prices) {
        int minSofar = prices[0];
        int maxprofit = 0;
        for(int i = 0;i<prices.length;i++){
            if(minSofar>prices[i]){
                minSofar = prices[i];
            }
            maxprofit = Math.max(maxprofit,prices[i]-minSofar);
        }
        return maxprofit;
    }
}
